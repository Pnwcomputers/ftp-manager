# --- FTP Credentials & Config (CRITICAL) ---
# Never track your actual server connection details
credentials.json
.env
config.local.json
secrets.py
*.conf
*.settings

# --- Local Sync & Temp Data ---
# Ignore the actual files being transferred/synched
/downloads/
/uploads/
/sync_folder/
/data/
*.tmp
*.bak

# --- Logging ---
# FTP logs can reveal your full remote directory structure
*.log
logs/

# --- Python / Development ---
__pycache__/
*.py[cod]
*$py.class
venv/
.venv/
env/
.env/
build/
dist/
*.spec

# --- Editor & OS ---
.vscode/
.idea/
.DS_Store
Thumbs.db
